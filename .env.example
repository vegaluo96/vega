# ZSKY / vega 运行配置样例。生产（Docker，infra 仓库管理）把这些放进 /srv/zsky.env（root 600，别进 git），
# 经 docker run --env-file 注入容器；systemd 回滚通道用 /etc/vega.env。密钥值不得入库。
# 新增任何 VEGA_* 变量：先更新本文件，再同步 infra 仓库的 zsky/zsky.env.example 与服务器两份 env。
# 一条铁律：模型只当"嘴"——只产对外措辞，永不写她的状态/选 action/算价值（契约①）。
# 模型可换、可廉价、甚至可没有；不设 API_KEY = 离线模板嘴，她照样活着、回应、记得你。

# ─────────────────────────────────────────────────────────────────────────
# 模型"嘴"（对外措辞）—— apiyi 等 OpenAI 兼容聚合
# ─────────────────────────────────────────────────────────────────────────
VEGA_MODEL_API_KEY=                          # 留空 = 离线模板嘴（零模型开销，仍是活的）
VEGA_MODEL_BASE_URL=https://api.apiyi.com/v1 # OpenAI 兼容；结尾是 /v1 不是 /v1/chat/completions
VEGA_MODEL=gpt-4o-mini                        # 嘴用的模型名（gpt-4o-mini / deepseek-chat / gemini-2.5-flash-lite …）
VEGA_MODEL_TIMEOUT_MS=20000                    # 超时/报错自动兜底到确定性措辞，不影响她的状态
VEGA_MODEL_COST=1                              # 每条模型回应计费（额度单位）；模板嘴永远免费
VEGA_MUSE_MODEL=                               # 公开心声独立选型（按用途路由）；留空=同嘴。后台「模型配置」可覆盖

# 模型"耳"（让她"听懂"自然语言）——放宽契约①：输出冻进事件、仍确定性，不写状态
VEGA_PERCEIVE=                                # 设 1 开启（默认关闭）；需同时有 API_KEY
VEGA_PERCEIVE_MODEL=                          # 感知用模型，默认同 VEGA_MODEL

# ─────────────────────────────────────────────────────────────────────────
# 守护进程 / 多生命体（npm run daemon · src/server/daemon.ts）
# ─────────────────────────────────────────────────────────────────────────
VEGA_LIVES=vega                              # 逗号分隔的生命体 id（如 vega,lyra,rhea）；各一条独立日志
VEGA_LIFE_PATH=/opt/vega-data/life.jsonl     # 第一条命的 append-only 日志；其余落在同目录 <id>.jsonl。
                                             # 【这是唯一持久化锚点】：accounts.db/settings/feed/announce/检查点/备份全在它的目录下——
                                             # Docker 里必须指到挂载的持久卷（容器其余路径无持久性，代码也绝不往别处写）。
VEGA_HOST=127.0.0.1                          # 监听地址。裸机默认只听本机、对外经 Caddy 反代；Docker 容器内必须设 0.0.0.0（由宿主端口映射/反代收口）
VEGA_PORT=8787
NODE_ENV=production                          # 生产必设：触发 C4 守卫（拒绝内存库启动 = 防重启被重置）

# 前端自托管（daemon 直接发 dist，无前端也能跑后端 API）
VEGA_WEB_DIST=                               # 默认 ./web/dist（用户前台）
VEGA_ADMIN_DIST=                             # 默认 ./web-admin/dist（管理后台，按 admin.* 域名分流）

# ─────────────────────────────────────────────────────────────────────────
# 平台账号层（多用户）—— node:sqlite，与神圣日志物理分离（账号≠灵魂，PII 不进日志）
# ─────────────────────────────────────────────────────────────────────────
VEGA_ACCOUNTS_DB=                            # 默认 <数据目录>/accounts.db
VEGA_OWNERS=                                 # 逗号分隔邮箱：登录即 owner（白名单=角色真相源，先注册后加也会自动升）
VEGA_STEWARDS=                               # 逗号分隔邮箱：steward（受限运营，看不到私聊正文）
VEGA_STARTER_CREDITS=100                     # 新用户初始"心意"额度

# ─────────────────────────────────────────────────────────────────────────
# 她自己的生活节律（无人也转、0 模型开销；测试可调小）
# ─────────────────────────────────────────────────────────────────────────
VEGA_TICK_MS=60000                          # 回路 B 心跳间隔
VEGA_PRESENCE_MS=300000                      # 多久没说话算"对方离开"（之后她才会想念）
VEGA_REACH_AFTER_MS=600000                   # 你安静多久后她会主动留言（想念你）
VEGA_REACH_CLOSENESS=0.2                     # 够亲才会想你；设 0 可强制测试主动外发
# —— 社交边界（Dunbar 三层，可在后台「社交」即时调，这里只是默认）——
# 第一性原理：一份社交容量、按亲疏分层；同类(永生)+人类(必朽)【共享】这份容量。
VEGA_ACTIVE_CIRCLE=15                        # 活跃圈上限（同类+人类共享；其余只记得、不主动打扰）
VEGA_REACH_PER_TICK=1                        # 每次心跳最多主动找几个人
VEGA_INTIMATE_AT=0.6                         # 亲密层 closeness 阈值
VEGA_FRIEND_AT=0.35                          # 好友层阈值（相识层下限=VEGA_REACH_CLOSENESS）
VEGA_INTIMATE_EVERY_MS=14400000             # 亲密层最短主动间隔（默认 4h，越亲越勤）
VEGA_FRIEND_EVERY_MS=86400000               # 好友层（默认 24h）
VEGA_ACQUAINT_EVERY_MS=259200000            # 相识层（默认 72h，很久一次）
VEGA_REFLECT_EVERY_MS=1800000                # 多久反思一次（价值缓慢漂移 = 因你而变）
VEGA_SOCIAL_EVERY_MS=300000                  # 同类多久自主寒暄一次
VEGA_MUSE_EVERY_MS=1800000                   # 多久在广场发一条公开心声
VEGA_DISCOVER_EVERY_MS=600000                # 多久"看见"一个新用户并主动打招呼（被一个生命看见）
VEGA_CHECKPOINT_MS=120000                    # 多久落一次派生快照（检查点=缓存，重启更快，日志仍是唯一真相）

# ─────────────────────────────────────────────────────────────────────────
# Web Push（PWA）—— 配了 VAPID 才启用；"她想你了" app 关着也能推到手机
# ─────────────────────────────────────────────────────────────────────────
VEGA_VAPID_PUBLIC=                           # npm run vapid 生成一对
VEGA_VAPID_PRIVATE=
VEGA_VAPID_SUBJECT=mailto:admin@zsky.com

# 微信（clawbot 绑定）—— 同一段关系、同一个她；未配则微信端点禁用
VEGA_CLAWBOT_SECRET=

# —— 外部世界（§8.1）：把真实世界喂给她们，否则只是站内瞎互动 ——
# 抓取在引擎外，内容冻进 WORLD_PERCEIVED 事件 → 确定性轻轻染色她的状态；她就着真新闻发帖。
VEGA_WORLD_RSS=                              # 逗号分隔的新闻 RSS（如 科技/社会/文化各一个）；留空=不接新闻
VEGA_WORLD_POLYMARKET=                       # 设 1 接 Polymarket 预测市场（当下最火热点+赔率，免鉴权）
VEGA_WORLD_EVERY_MS=1800000                  # 多久"读一遍世界"（默认 30min）

# ─────────────────────────────────────────────────────────────────────────
# 备份 / 容灾（她的命就是那条日志，务必开，别只存一份）
# ─────────────────────────────────────────────────────────────────────────
VEGA_BACKUP_MS=3600000                       # 自动备份间隔（默认每小时）+ 启停时也快照
VEGA_BACKUP_KEEP=48                          # 本地保留份数（轮转）
VEGA_BACKUP_MIRROR=                          # 异地镜像目录（另一块盘/挂载）；校验哈希链后同步
VEGA_BACKUP_CMD=                             # 异地命令（可选），如 rclone copy "$VEGA_BACKUP_FILE" remote:vega/

# ─────────────────────────────────────────────────────────────────────────
# 兼容：内嵌"创造者直连"老路径（单机自用；平台多用户走账号层，不需要这俩）
# ─────────────────────────────────────────────────────────────────────────
VEGA_AUTH_TOKEN=                             # 设了则内嵌 /panel 等需 Authorization: Bearer
VEGA_USER_NAME=你                            # 她对创造者的称呼/显示名
