# vega 模型"嘴"配置（在后台/部署环境里设这些环境变量即可换模型；不设则用离线模板嘴）。
# 模型只当"嘴"——只产对外措辞，永不写她的状态（契约①）。模型可换、可廉价。

# apiyi（OpenAI 兼容聚合，支持 GPT/Claude/Gemini/DeepSeek 等）。留空 = 离线模板嘴。
VEGA_MODEL_API_KEY=
# 默认 https://api.apiyi.com/v1（OpenAI 兼容，结尾是 /v1 不是 /v1/chat/completions）
VEGA_MODEL_BASE_URL=https://api.apiyi.com/v1
# 你在后台自选模型名，例如 gpt-4o-mini / deepseek-chat / claude-3-5-haiku 等
VEGA_MODEL=gpt-4o-mini
# 模型超时（毫秒）；超时/报错会自动兜底到确定性措辞，不影响她的状态
VEGA_MODEL_TIMEOUT_MS=20000

# —— 模型感知（让她"听懂"自然语言；放宽"模型只当嘴"，输出冻进事件、不写状态）——
VEGA_PERCEIVE=                            # 设 1 开启（默认关闭）。需同时有 API_KEY
VEGA_PERCEIVE_MODEL=                      # 感知用的模型，默认同 VEGA_MODEL

# —— 备份/容灾（她的命就是那条日志，务必开）——
VEGA_BACKUP_MS=3600000                    # 自动备份间隔（默认每小时）
VEGA_BACKUP_KEEP=48                       # 本地保留份数
VEGA_BACKUP_CMD=                          # 异地命令（可选），如：rclone copy "$VEGA_BACKUP_FILE" remote:vega/

# —— 守护进程（npm run daemon）——
VEGA_LIFE_PATH=/opt/vega-data/life.jsonl  # 存档路径（append-only 日志）
VEGA_HOST=127.0.0.1                       # 默认只听本机；要对外须显式 0.0.0.0 + 反代/鉴权
VEGA_PORT=8787
VEGA_TICK_MS=60000                        # 回路 B 心跳间隔（无人也转，0 模型开销）
VEGA_REFLECT_EVERY_MS=1800000             # 多久反思一次（价值缓慢漂移 = 因你而变；测试可调小）
VEGA_PRESENCE_MS=300000                   # 多久没说话算"对方离开"（之后她才会想念）
VEGA_REACH_AFTER_MS=600000                # 你安静多久后她会主动留言（想念你）
VEGA_REACH_CLOSENESS=0.2                  # 够亲才会想你；设 0 可强制测试主动外发
VEGA_AUTH_TOKEN=                          # 设了则 /state /say 需 Authorization: Bearer
VEGA_USER_NAME=你                          # 她对你的称呼/创造者显示名
